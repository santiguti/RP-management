# Copy to `.env` and fill in real values. `.env` is gitignored.

# ─── App ─────────────────────────────────────────────────
APP_ENV=dev                  # dev | prod
HTTP_ADDR=:8080

# ─── Database ────────────────────────────────────────────
POSTGRES_USER=rp
POSTGRES_DB=rp
POSTGRES_PASSWORD=            # generate with: openssl rand -hex 16
DATABASE_URL=postgres://rp:${POSTGRES_PASSWORD}@postgres:5432/rp?sslmode=disable

# ─── Auth ────────────────────────────────────────────────
COOKIE_SECRET=                # generate with: openssl rand -hex 32

# ─── Public access (v1.x) ────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=      # from Cloudflare Zero Trust dashboard
